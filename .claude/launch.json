{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "garage-app",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["/opt/homebrew/lib/node_modules/npm/bin/npm-cli.js", "run", "dev"],
      "port": 3001,
      "autoPort": true,
      "env": {
        "NODE_OPTIONS": "--max-old-space-size=4096",
        "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"
      }
    }
  ]
}
